# Cell 4: Generate synthetic images at multiple spatial scales
# This is KEY to the receptive field experiment

def make_grating(size=224, frequency=10, angle=0):
    """Sinusoidal grating - tests spatial frequency sensitivity."""
    x = np.linspace(0, 1, size)
    X, Y = np.meshgrid(x, x)
    angle_rad = np.deg2rad(angle)
    grating = np.sin(2 * np.pi * frequency *
                     (X * np.cos(angle_rad) + Y * np.sin(angle_rad)))
    grating = ((grating + 1) / 2 * 255).astype(np.uint8)
    img = np.stack([grating]*3, axis=-1)
    return Image.fromarray(img)

def make_checkerboard(size=224, block_size=8):
    """Checkerboard - tests local vs global pattern detection."""
    board = np.zeros((size, size), dtype=np.uint8)
    for i in range(size):
        for j in range(size):
            if (i // block_size + j // block_size) % 2 == 0:
                board[i, j] = 255
    img = np.stack([board]*3, axis=-1)
    return Image.fromarray(img)

def make_large_shape(size=224, shape_size_ratio=0.5):
    """Large centered shape - needs global/large receptive field."""
    canvas = np.zeros((size, size, 3), dtype=np.uint8)
    center = size // 2
    radius = int(size * shape_size_ratio / 2)
    cv2.circle(canvas, (center, center), radius, (200, 100, 50), -1)
    return Image.fromarray(canvas)

# Pattern scales: frequency (high=fine detail, low=coarse)
scales = {
    'fine_texture (freq=40)':    make_grating(frequency=40),
    'medium_texture (freq=20)':  make_grating(frequency=20),
    'coarse_texture (freq=8)':   make_grating(frequency=8),
    'small_checker (block=4)':   make_checkerboard(block_size=4),
    'large_checker (block=28)':  make_checkerboard(block_size=28),
    'small_shape (ratio=0.15)':  make_large_shape(shape_size_ratio=0.15),
    'large_shape (ratio=0.75)':  make_large_shape(shape_size_ratio=0.75),
}

