# Cell 2: YOLO Format Dataset Loader for Indian Road Obstacle Dataset

import os
import torch
from torch.utils.data import Dataset, DataLoader, Subset
from PIL import Image
import torchvision.transforms as transforms

DATASET_PATH = '/kaggle/input/datasets/srikrishnaanirudh/indianroadobstacle/IndianRoadObstacleDetectionDataset_DLCV'
CLASSES = ['potholes', 'animal', 'thelas', 'barricades', 'rickshaws']
NUM_CLASSES = len(CLASSES)
BATCH_SIZE = 16
IMG_SIZE = 224

transform = transforms.Compose([
    transforms.Resize((IMG_SIZE, IMG_SIZE)),
    transforms.ToTensor(),
    transforms.Normalize(mean=[0.485, 0.456, 0.406],
                         std=[0.229, 0.224, 0.225])
])

class YOLORoadDataset(Dataset):
    def __init__(self, root, splits=('train', 'val', 'test'), transform=None):
        self.root      = root
        self.transform = transform
        self.samples   = []   # list of (img_path, class_idx)
        self.class_to_idx = {cls: i for i, cls in enumerate(CLASSES)}

        IMG_EXTS = ('.jpg', '.jpeg', '.png', '.bmp', '.webp')

        for split in splits:
            img_dir = os.path.join(root, 'images', split)
            ann_dir = os.path.join(root, 'annotations', split)

            if not os.path.exists(img_dir):
                continue

            for img_file in os.listdir(img_dir):
                if not img_file.lower().endswith(IMG_EXTS):
                    continue

                img_path  = os.path.join(img_dir, img_file)
                stem      = os.path.splitext(img_file)[0]
                ann_path  = os.path.join(ann_dir, stem + '.txt')

                if not os.path.exists(ann_path):
                    continue

                # Read YOLO annotation — each line: class_id cx cy w h
                with open(ann_path) as f:
                    lines = [l.strip() for l in f if l.strip()]

                if not lines:
                    continue

                # Use the first (or dominant) class in the annotation
                class_ids = []
                for line in lines:
                    parts = line.split()
                    if len(parts) >= 1:
                        try:
                            class_ids.append(int(parts[0]))
                        except ValueError:
                            continue

                if not class_ids:
                    continue

                # Pick the most frequent class in this image
                dominant_class = max(set(class_ids), key=class_ids.count)

                if dominant_class < NUM_CLASSES:
                    self.samples.append((img_path, dominant_class))

        # Summary
        from collections import Counter
        counts = Counter(label for _, label in self.samples)
        print(f"Total samples loaded: {len(self.samples)}")
        for idx in range(NUM_CLASSES):
            print(f"  {CLASSES[idx]:12s}: {counts.get(idx, 0)} images")

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, idx):
        img_path, label = self.samples[idx]
        img = Image.open(img_path).convert('RGB')
        if self.transform:
            img = self.transform(img)
        return img, label

    # Helper: get raw PIL image by index (needed for GradCAM later)
    def get_pil(self, idx):
        img_path, label = self.samples[idx]
        return Image.open(img_path).convert('RGB'), label, img_path


