# Cell 7: GradCAM heatmaps on your actual road obstacle images

from pytorch_grad_cam import GradCAM
from pytorch_grad_cam.utils.image import show_cam_on_image
from pytorch_grad_cam.utils.model_targets import ClassifierOutputTarget

def get_gradcam_heatmap(model, img_tensor_raw, img_np, target_class=None):
    """Generate GradCAM heatmap for a model."""
    target_layers = [model.layer4[-1]]   # last residual block
    cam = GradCAM(model=model, target_layers=target_layers)

    targets = [ClassifierOutputTarget(target_class)] if target_class is not None else None
    grayscale_cam = cam(input_tensor=img_tensor_raw, targets=targets)
    grayscale_cam = grayscale_cam[0]

    visualization = show_cam_on_image(img_np, grayscale_cam, use_rgb=True)
    return grayscale_cam, visualization

