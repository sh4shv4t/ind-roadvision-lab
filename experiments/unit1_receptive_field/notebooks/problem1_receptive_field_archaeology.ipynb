# Cell 5: Measure how confidently each model responds to each pattern
# We use the variance of feature maps as proxy for "representability"

preprocess = transforms.Compose([
    transforms.Resize((224, 224)),
    transforms.ToTensor(),
    transforms.Normalize([0.485,0.456,0.406],[0.229,0.224,0.225])
])

def get_feature_response(model, image_pil, layer_name='layer4'):
    """Extract feature map variance from a given layer."""
    activations = {}
    def hook_fn(module, input, output):
        activations['feat'] = output.detach().cpu()

    # Register hook on specified layer
    layer = dict(model.named_modules())[layer_name]
    hook = layer.register_forward_hook(hook_fn)

    tensor = preprocess(image_pil).unsqueeze(0).to(device)
    with torch.no_grad():
        _ = model(tensor)
    hook.remove()

    feat = activations['feat']
    return feat.var().item()   # Variance = how much the pattern activated the layer

# Collect responses
response_matrix = {}  # model -> {pattern -> response}

for model_name, model in models_dict.items():
    response_matrix[model_name] = {}
    for pattern_name, pattern_img in scales.items():
        resp = get_feature_response(model, pattern_img)
        response_matrix[model_name][pattern_name] = resp
    print(f"  ✓ {model_name} done")

print("\nFeature responses collected!")


