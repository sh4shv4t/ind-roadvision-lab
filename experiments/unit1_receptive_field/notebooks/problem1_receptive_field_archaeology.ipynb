# Cell 9: Estimate *effective* receptive field using gradient magnitude

def estimate_effective_rf(model, input_size=224):
    """
    Compute effective RF by backpropagating gradients from center
    neuron of the last conv layer back to the input.
    """
    model.eval()
    inp = torch.zeros(1, 3, input_size, input_size,
                      requires_grad=True, device=device)

    # Forward through conv layers only (up to layer4)
    x = inp
    x = model.conv1(x)
    x = model.bn1(x)
    x = model.relu(x)
    x = model.maxpool(x)
    x = model.layer1(x)
    x = model.layer2(x)
    x = model.layer3(x)
    x = model.layer4(x)

    # Pick center neuron of first channel
    h, w = x.shape[2], x.shape[3]
    center_val = x[0, 0, h // 2, w // 2]

    center_val.backward()

    # Gradient magnitude at input = effective RF footprint
    grad = inp.grad.data.abs().squeeze()
    grad = grad.mean(dim=0).cpu().numpy()
    grad = (grad - grad.min()) / (grad.max() - grad.min() + 1e-8)
    return grad

print("Computing effective receptive fields...")
eff_rfs = {}
for model_name, model in models_dict.items():
    eff_rfs[model_name] = estimate_effective_rf(model)
    print(f"  ✓ {model_name}")

# --- Plot ERF side by side ---
fig, axes = plt.subplots(1, 3, figsize=(15, 5))
cmaps = ['hot', 'plasma', 'viridis']

for idx, (model_name, erf) in enumerate(eff_rfs.items()):
    im = axes[idx].imshow(erf, cmap=cmaps[idx])
    axes[idx].set_title(
        f'{model_name}\nTheoretical RF: {theoretical_rf[model_name]}px',
        fontsize=12, fontweight='bold')
    axes[idx].axis('off')
    plt.colorbar(im, ax=axes[idx], fraction=0.046)

    # Draw circle showing high-gradient region
    threshold = 0.3
    mask = erf > threshold
    ys, xs = np.where(mask)
    if len(xs) > 0:
        erf_size = xs.max() - xs.min()
        print(f"  {model_name} effective RF span: ~{erf_size}px (threshold={threshold})")

plt.suptitle('Effective Receptive Fields (Gradient-Based)\nResNet-18 vs 50 vs 152',
             fontsize=13, fontweight='bold')
